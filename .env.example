# ──────────────────────────────────────────────
# remarkable-to-bear configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# OpenAI model to use (must support vision)
OPENAI_MODEL=gpt-4o

# reMarkable cloud notebook name to search for (case-insensitive regex)
RMAPI_SEARCH_TERM=Quick sheets

# Delete the notebook from reMarkable cloud after successful processing
DELETE_AFTER_PROCESSING=true

# Create action items from handwritten notes
CREATE_REMINDERS=true

# Todo app for action items: "reminders", "things", or "both"
TODO_APP=reminders

# Default Reminders.app list for action items
DEFAULT_REMINDERS_LIST=Work

# Default Things 3 project for action items (leave empty for Inbox)
DEFAULT_THINGS_LIST=

# Image conversion settings
IMAGE_DPI=170
MAX_PAGES=12

# Set to true to print raw model output for debugging
DEBUG_RAW_OUTPUT=false
